{
  "openapi": "3.0.0",
  "info": {
    "title": "Short URL Generator API",
    "description": "A simple URL shortener service built with Go and PostgreSQL.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/shorten": {
      "post": {
        "summary": "Shorten a long URL",
        "description": "Take a long URL and return a unique 6-character short code",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShortenRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShortenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{short_code}": {
      "get": {
        "summary": "Redirect to original URL",
        "description": "Take a 6-character short code and redirect the user to the original long URL",
        "parameters": [
          {
            "name": "short_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The 6-character unique code"
          }
        ],
        "responses": {
          "302": {
            "description": "Found (Redirect)"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/stats/{short_code}": {
      "get": {
        "summary": "Get statistics for a short URL",
        "description": "Return metadata and hit count for a given short code",
        "parameters": [
          {
            "name": "short_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The 6-character unique code"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/URL"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ShortenRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://example.com"
          }
        }
      },
      "ShortenResponse": {
        "type": "object",
        "properties": {
          "short_url": {
            "type": "string",
            "example": "http://localhost:8081/aB3dE1"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "invalid request body"
          }
        }
      },
      "URL": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "short_code": {
            "type": "string"
          },
          "original_url": {
            "type": "string"
          },
          "hits": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}